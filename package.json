{
  "name": "@cboxdk/telemetry-browser",
  "version": "0.1.0-alpha.3",
  "description": "Deep browser RUM SDK for cboxdk/laravel-telemetry \u2014 page load, Web Vitals, fetch/XHR, errors and SPA routes, correlated with your backend traces.",
  "type": "module",
  "license": "MIT",
  "author": "Sylvester Damgaard <sn@cbox.dk>",
  "homepage": "https://github.com/cboxdk/telemetry-browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/cboxdk/telemetry-browser.git"
  },
  "keywords": [
    "rum",
    "telemetry",
    "observability",
    "tracing",
    "web-vitals",
    "laravel",
    "opentelemetry"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/telemetry.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sourcemaps": {
      "types": "./dist/sourcemaps.d.ts",
      "import": "./dist/sourcemaps.js",
      "require": "./dist/sourcemaps.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "bin": {
    "telemetry-sourcemaps": "./dist/cli.cjs"
  }
}
